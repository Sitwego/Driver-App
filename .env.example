# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real URLs.

# Dev ngrok tunnel (change whenever you restart ngrok)
EXPO_PUBLIC_API_BASE_URL_DEV=

# Production REST API base URL
EXPO_PUBLIC_API_BASE_URL=

# File / media server base URL (leave empty to use the API server)
EXPO_PUBLIC_FILE_BASE_URL=

# Android Google Maps API key (build-time only — from Google Cloud Console)
GOOGLE_MAPS_API_KEY=
